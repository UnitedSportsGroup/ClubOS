# ClubOS environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.supabase.co:5432/postgres

# Server
NODE_ENV=development
PORT=5001
SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Email (Resend)
RESEND_API_KEY=

# Meta tracking (Facebook Pixel + Conversions API)
META_PIXEL_ID=
VITE_META_PIXEL_ID=
META_ACCESS_TOKEN=

# DNS automation (GoDaddy)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Initial admin user (used by seed script on first boot)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Object storage — TODO: replace Replit storage with Supabase Storage credentials
# (will be wired in next phase, app boots without these for now)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clubos-uploads
